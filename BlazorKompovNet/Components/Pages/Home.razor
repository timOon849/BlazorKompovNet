@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IDashboardService DashboardService
@inject IClubManagementService ClubManagementService
@inject AuthenticationStateProvider AuthenticationStateProvider
<PageTitle>дЮЬАНПД ЙКСАЮ</PageTitle>

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1>дЮЬАНПД ЙКСАЮ</h1>
        <p class="text-muted mb-0">яБНДЙЮ ОН РЕЙСЫЕЛС ЙКСАС, ЯЛЕМЕ Х ЯНЯРНЪМХЧ ГЮКЮ.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(notification))
{
    <div class="alert alert-info">@notification</div>
}

@if (stats is null)
{
    <p><em>гЮЦПСГЙЮ ДЮММШУ...</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-center">
                <div class="col-lg-6">
                    <p class="text-muted mb-1">рЕЙСЫХИ ЙКСА ОПХКНФЕМХЪ</p>
                    <h2 class="h4 mb-1">@(stats.CurrentClub?.Name ?? "йКСА МЕ БШАПЮМ")</h2>
                    <p class="mb-0 text-muted">@(stats.CurrentClub?.Address ?? "юДПЕЯ МЕ СЙЮГЮМ")</p>
                </div>

                <div class="col-sm-4 col-lg-2">
                    <div class="border rounded p-3">
                        <div class="text-muted small">ID ЙКСАЮ</div>
                        <div class="h5 mb-0">@(stats.CurrentClub?.Id.ToString() ?? "-")</div>
                    </div>
                </div>

                <div class="col-sm-4 col-lg-2">
                    <div class="border rounded p-3">
                        <div class="text-muted small">йКСАНБ Б ЯЕРХ</div>
                        <div class="h5 mb-0">@stats.AvailableClubs.Count</div>
                    </div>
                </div>

                <div class="col-sm-4 col-lg-2">
                    <div class="border rounded p-3">
                        <div class="text-muted small">яРЮРСЯ</div>
                        <span class="badge @(stats.CurrentClub?.IsActive == true ? "text-bg-success" : "text-bg-secondary")">
                            @(stats.CurrentClub?.IsActive == true ? "юЙРХБЕМ" : "мЕЮЙРХБЕМ")
                        </span>
                    </div>
                </div>
            </div>

            @if (stats.AvailableClubs.Count > 1)
            {
                <div class="mt-3 pt-3 border-top">
                    <div class="text-muted small mb-2">дНЯРСОМШЕ ЙКСАШ</div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var club in stats.AvailableClubs)
                        {
                            <span class="badge @(club.Id == stats.CurrentClub?.Id ? "text-bg-primary" : "text-bg-secondary")">
                                @club.Name
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card h-100 border-success">
                <div class="card-body">
                    <p class="text-muted mb-1">бШПСВЙЮ ГЮ ДЕМЭ</p>
                    <h2 class="h3 mb-0">@FormatMoney(stats.RevenueToday)</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">бШПСВЙЮ ЯЛЕМШ</p>
                    <h2 class="h3 mb-0">@FormatMoney(stats.RevenueCurrentShift)</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">оНЯЕРХРЕКЕИ ЯЕЦНДМЪ</p>
                    <h2 class="h3 mb-0">@stats.VisitorsToday</h2>
                    <p class="small text-muted mb-0">яЕИВЮЯ Б ЙКСАЕ: @stats.ActiveVisitors</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">аПНМХПНБЮМХИ ЯЕЦНДМЪ</p>
                    <h2 class="h3 mb-0">@stats.BookingsToday</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">юЙРХБМШУ ЯЕЯЯХИ</p>
                    <h2 class="h3 mb-0">@stats.ActiveSessionsCount</h2>
                    <p class="small text-muted mb-0">гЮБЕПЬЕМН ЯЕЦНДМЪ: @stats.CompletedSessionsToday</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">оНОНКМЕМХИ ЯЕЦНДМЪ</p>
                    <h2 class="h3 mb-0">@stats.TopUpsToday</h2>
                    <p class="small text-muted mb-0">мЮ ЯСЛЛС @FormatMoney(stats.TopUpAmountToday)</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">бШЙКЧВЕМН</p>
                    <h2 class="h3 mb-0">@stats.DisabledComputers</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">яОПЮБНВМХЙ</p>
                    <a class="btn btn-outline-primary btn-sm" href="/tariffs">рЮПХТШ ЙКСАЮ</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">яНЯРНЪМХЕ ЙНЛОЭЧРЕПНБ</h2>

                    <div class="row text-center g-3 mt-1">
                        <div class="col-6 col-md-3">
                            <div class="border rounded p-3">
                                <div class="h3 mb-0 text-success">@stats.AvailableComputers</div>
                                <div class="text-muted small">яБНАНДМН</div>
                            </div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="border rounded p-3">
                                <div class="h3 mb-0 text-primary">@stats.BusyComputers</div>
                                <div class="text-muted small">гЮМЪРН</div>
                            </div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="border rounded p-3">
                                <div class="h3 mb-0 text-warning">@stats.ReservedComputers</div>
                                <div class="text-muted small">аПНМЭ</div>
                            </div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="border rounded p-3">
                                <div class="h3 mb-0 text-danger">@stats.MaintenanceComputers</div>
                                <div class="text-muted small">пЕЛНМР</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">рЕЙСЫЮЪ ЯЛЕМЮ</h2>

                    @if (stats.CurrentShift is null)
                    {
                        <div class="alert alert-warning">
                            нРЙПШРНИ ЯЛЕМШ МЕР. йЮЯЯНБШЕ НОЕПЮЖХХ МЕДНЯРСОМШ ДН НРЙПШРХЪ ЯЛЕМШ.
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="openingCashAmount">яСЛЛЮ Б ЙЮЯЯЕ МЮ ЯРЮПРЕ</label>
                            <input class="form-control" id="openingCashAmount" type="number" min="0" step="100" @bind="openingCashAmount" />
                        </div>

                        <button class="btn btn-primary" type="button" @onclick="OpenShiftAsync">нРЙПШРЭ ЯЛЕМС</button>
                    }
                    else
                    {
                        <dl class="row mb-0">
                            <dt class="col-sm-5">йЮЯЯХП</dt>
                            <dd class="col-sm-7">@stats.CurrentShift.Cashier?.FullName</dd>

                            <dt class="col-sm-5">нРЙПШРЮ</dt>
                            <dd class="col-sm-7">@stats.CurrentShift.OpenedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                            <dt class="col-sm-5">дКХРЕКЭМНЯРЭ</dt>
                            <dd class="col-sm-7">@FormatDuration(DateTime.Now - stats.CurrentShift.OpenedAt)</dd>

                            <dt class="col-sm-5">йЮЯЯЮ МЮ ЯРЮПРЕ</dt>
                            <dd class="col-sm-7">@FormatMoney(stats.CurrentShift.OpeningCashAmount)</dd>

                            <dt class="col-sm-5">яЕИВЮЯ Б ЙЮЯЯЕ</dt>
                            <dd class="col-sm-7">@FormatMoney(stats.CurrentShift.CurrentCashAmount)</dd>
                        </dl>

                        <div class="mt-3 pt-3 border-top">
                            <label class="form-label" for="closingCashAmount">тЮЙРХВЕЯЙЮЪ ЯСЛЛЮ Б ЙЮЯЯЕ</label>
                            <input class="form-control mb-2" id="closingCashAmount" type="number" min="0" step="100" @bind="closingCashAmount" />
                            <button class="btn btn-outline-danger" type="button" @onclick="CloseShiftAsync">гЮЙПШРЭ ЯЛЕМС</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardStats? stats;
    private string? notification;
    private decimal openingCashAmount;
    private decimal closingCashAmount;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        stats = await DashboardService.GetDashboardStatsAsync(authenticationState.User);
        closingCashAmount = stats.CurrentShift?.CurrentCashAmount ?? 0;
    }

    private async Task OpenShiftAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var cashierId = GetCashierId(authenticationState.User);
        var result = await ClubManagementService.OpenShiftAsync(cashierId, openingCashAmount);

        notification = result.Message;
        if (result.Succeeded)
        {
            openingCashAmount = 0;
        }

        await LoadStatsAsync();
    }

    private async Task CloseShiftAsync()
    {
        if (stats?.CurrentShift is null)
        {
            notification = "нРЙПШРЮЪ ЯЛЕМЮ МЕ МЮИДЕМЮ.";
            return;
        }

        var result = await ClubManagementService.CloseShiftAsync(stats.CurrentShift.Id, closingCashAmount);
        notification = result.Message;
        await LoadStatsAsync();
    }

    private static int GetCashierId(System.Security.Claims.ClaimsPrincipal user)
    {
        var cashierIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(cashierIdClaim, out var cashierId) ? cashierId : 0;
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} ?";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours} В {duration.Minutes} ЛХМ"
            : $"{duration.Minutes} ЛХМ";
    }
}
