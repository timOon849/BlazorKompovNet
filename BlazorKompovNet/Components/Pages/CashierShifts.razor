@page "/cashier-shifts"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IClubManagementService ClubManagementService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Кассовые смены</PageTitle>

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1>Кассовые смены</h1>
        <p class="text-muted mb-0">Открытие, закрытие и история смен кассиров.</p>
    </div>

    <button class="btn btn-outline-primary" type="button" @onclick="LoadDataAsync">Обновить</button>
</div>

@if (!string.IsNullOrWhiteSpace(notification))
{
    <div class="alert alert-info">@notification</div>
}

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Текущая смена</h2>

                @if (currentShift is null)
                {
                    <div class="alert alert-warning">
                        Открытой смены нет. Запуск сессий и пополнение баланса заблокированы.
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="shiftOpeningCash">Сумма в кассе на старте</label>
                        <input class="form-control" id="shiftOpeningCash" type="number" min="0" step="100" @bind="openingCashAmount" />
                        <div class="form-text">Укажите фактическую сумму наличных в кассе перед началом работы.</div>
                    </div>

                    <button class="btn btn-primary w-100" type="button" @onclick="OpenShiftAsync">Открыть смену</button>
                }
                else
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Номер</dt>
                        <dd class="col-sm-7">#@currentShift.Id</dd>

                        <dt class="col-sm-5">Кассир</dt>
                        <dd class="col-sm-7">@GetCashierName(currentShift)</dd>

                        <dt class="col-sm-5">Открыта</dt>
                        <dd class="col-sm-7">@ClubDateTime.Format(currentShift.OpenedAt)</dd>

                        <dt class="col-sm-5">Длительность</dt>
                        <dd class="col-sm-7">@FormatDuration(DateTime.UtcNow - currentShift.OpenedAt)</dd>

                        <dt class="col-sm-5">Старт кассы</dt>
                        <dd class="col-sm-7">@FormatMoney(currentShift.OpeningCashAmount)</dd>

                        <dt class="col-sm-5">Выручка смены</dt>
                        <dd class="col-sm-7">@FormatMoney(GetShiftRevenue(currentShift.Id))</dd>

                        <dt class="col-sm-5">Расчётная касса</dt>
                        <dd class="col-sm-7">@FormatMoney(GetExpectedCash(currentShift))</dd>
                    </dl>

                    <div class="mt-3 pt-3 border-top">
                        @if (activeSessionsCount > 0)
                        {
                            <div class="alert alert-warning py-2 small mb-3">
                                В клубе @activeSessionsCount активн@(activeSessionsCount == 1 ? "ая сессия" : activeSessionsCount < 5 ? "ые сессии" : "ых сессий").
                                Смену можно закрыть — сессии продолжатся, но пополнения и новые операции станут недоступны до открытия следующей смены.
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label" for="shiftClosingCash">Фактическая сумма при закрытии</label>
                            <input class="form-control" id="shiftClosingCash" type="number" min="0" step="100" @bind="closingCashAmount" />
                            <div class="form-text">Пересчитайте наличные в кассе перед закрытием смены.</div>
                        </div>

                        <button class="btn btn-outline-danger w-100" type="button" @onclick="CloseShiftAsync">Закрыть смену</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h2 class="h5 mb-3">История смен (@shifts.Count)</h2>

        @if (!shifts.Any())
        {
            <p class="text-muted mb-0">Смен пока нет.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Смена</th>
                            <th>Кассир</th>
                            <th>Открыта</th>
                            <th>Закрыта</th>
                            <th>Статус</th>
                            <th class="text-end">Старт кассы</th>
                            <th class="text-end">Выручка</th>
                            <th class="text-end">Итог кассы</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var shift in shifts)
                        {
                            <tr>
                                <td><strong>#@shift.Id</strong></td>
                                <td>@GetCashierName(shift)</td>
                                <td>@shift.OpenedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@(shift.ClosedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                <td>
                                    <span class="badge @(shift.IsOpen ? "text-bg-success" : "text-bg-secondary")">
                                        @(shift.IsOpen ? "Открыта" : "Закрыта")
                                    </span>
                                </td>
                                <td class="text-end">@FormatMoney(shift.OpeningCashAmount)</td>
                                <td class="text-end">@FormatMoney(GetShiftRevenue(shift.Id))</td>
                                <td class="text-end">@FormatMoney(shift.IsOpen ? GetExpectedCash(shift) : shift.CurrentCashAmount)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private IReadOnlyList<CashierShift> shifts = [];
    private IReadOnlyList<Transaction> transactions = [];
    private CashierShift? currentShift;
    private string? notification;
    private decimal openingCashAmount;
    private decimal closingCashAmount;

    private int activeSessionsCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        shifts = await ClubManagementService.GetCashierShiftsAsync();
        transactions = await ClubManagementService.GetTransactionsAsync();
        currentShift = await ClubManagementService.GetCurrentShiftAsync();
        activeSessionsCount = (await ClubManagementService.GetActiveSessionsAsync()).Count;
        closingCashAmount = currentShift is null ? 0 : GetExpectedCash(currentShift);
    }

    private decimal GetShiftRevenue(int shiftId) =>
        ShiftAccounting.GetShiftRevenue(transactions, shiftId);

    private decimal GetExpectedCash(CashierShift shift) =>
        ShiftAccounting.GetExpectedCashAmount(shift, transactions);

    private async Task OpenShiftAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var result = await ClubManagementService.OpenShiftAsync(GetCashierId(authenticationState.User), openingCashAmount);

        notification = result.Message;
        if (result.Succeeded)
        {
            openingCashAmount = 0;
        }

        await LoadDataAsync();
    }

    private async Task CloseShiftAsync()
    {
        if (currentShift is null)
        {
            notification = "Открытая смена не найдена.";
            return;
        }

        var result = await ClubManagementService.CloseShiftAsync(currentShift.Id, closingCashAmount);
        notification = result.Message;
        await LoadDataAsync();
    }

    private static int GetCashierId(System.Security.Claims.ClaimsPrincipal user)
    {
        var cashierIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(cashierIdClaim, out var cashierId) ? cashierId : 0;
    }

    private static string GetCashierName(CashierShift shift)
    {
        return shift.Cashier?.FullName ?? $"Кассир #{shift.CashierId}";
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} ₽";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours} ч {duration.Minutes} мин"
            : $"{duration.Minutes} мин";
    }
}
