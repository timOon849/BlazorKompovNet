    private static string GetSessionTimeLeftText(GameSession session)
    {
        var timeLeft = session.PlannedEndAt - DateTime.Now;
        if (timeLeft <= TimeSpan.Zero)
        {
            return "истекло";
        }

        return timeLeft.TotalHours >= 1
            ? $"{(int)timeLeft.TotalHours} ч {timeLeft.Minutes} мин"
            : $"{timeLeft.Minutes} мин";
    }

    private static string GetSessionTimeTextClass(GameSession session)
    {
        var timeLeft = session.PlannedEndAt - DateTime.Now;
        return timeLeft <= TimeSpan.Zero
            ? "small text-danger fw-semibold"
            : timeLeft.TotalMinutes <= 15
                ? "small text-warning-emphasis fw-semibold"
                : "small text-muted";
    }

    private static int GetSessionProgressPercent(GameSession session)
    {
        var total = session.PlannedEndAt - session.StartedAt;
        if (total.TotalSeconds <= 0)
        {
            return 100;
        }

        var elapsed = DateTime.Now - session.StartedAt;
        return Math.Clamp((int)Math.Round(elapsed.TotalSeconds / total.TotalSeconds * 100), 0, 100);
    }

    private static string GetSessionProgressClass(GameSession session)
    {
        var timeLeft = session.PlannedEndAt - DateTime.Now;
        return timeLeft <= TimeSpan.Zero
            ? "bg-danger"
            : timeLeft.TotalMinutes <= 15
                ? "bg-warning"
                : "bg-primary";
    }
