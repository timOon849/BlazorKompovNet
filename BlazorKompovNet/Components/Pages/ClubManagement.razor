    }

    private void OpenComputerMenu(MouseEventArgs args, Computer computer)
    {
        contextMenuComputer = computer;
        contextMenuX = args.ClientX;
        contextMenuY = args.ClientY;
        showComputerMenu = true;
    }

    private void CloseComputerMenu()
    {
        showComputerMenu = false;
        contextMenuComputer = null;
    }

    private GameSession? GetActiveSession(int computerId)
    {
        return activeSessions.FirstOrDefault(session => session.ComputerId == computerId);
    }

    private Booking? GetActiveBooking(int computerId)
    {
        return activeBookings.FirstOrDefault(booking => booking.ComputerId == computerId);
    }

    private static string GetClientName(Client? client) => ModelLabels.GetClientDisplayName(client);

    private int CountComputers(string statusCode)
    {
        return zones.SelectMany(zone => zone.Computers)
            .Count(computer => computer.Status?.Code == statusCode);
    }

    private bool CanStartSession(Computer computer)
    {
        return HasOpenShift && computer.Status?.CanStartSession == true;
    }

    private decimal CalculateSessionPrice()
    {
        if (SelectedTariff is null)
        {
            return 0;
        }

        var price = GetTariffPrice(SelectedTariff, selectedComputer?.ZoneId ?? 0);

        return SelectedTariff.IsHourly
            ? price * Math.Max(sessionHours, 0.5m)
            : price;
    }

    private decimal CalculateExtendPrice()
    {
        if (SelectedExtendTariff is null)
        {
            return 0;
        }

        var price = GetTariffPrice(SelectedExtendTariff, selectedSession?.Computer?.ZoneId ?? 0);

        return SelectedExtendTariff.IsHourly
            ? price * Math.Max(extendHours, 0.5m)
            : price;
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} ₽";
    }

    private static decimal GetTariffPrice(Tariff tariff, int zoneId)
    {
        return tariff.TariffZones.FirstOrDefault(tariffZone => tariffZone.ZoneId == zoneId)?.Price ?? 0;
    }

    private static string GetStatusText(ComputerStatus? status)
    {
        return status?.Name ?? "Неизвестно";
    }

    private static string GetStatusBadgeClass(ComputerStatus? status)
    {
        return status?.Code switch
        {
            ComputerStatusCodes.Available => "text-bg-success",
            ComputerStatusCodes.Busy => "text-bg-primary",
            ComputerStatusCodes.Reserved => "text-bg-warning",
            ComputerStatusCodes.Maintenance => "text-bg-danger",
            ComputerStatusCodes.Disabled => "text-bg-secondary",
            _ => "text-bg-light"
        };
    }

    private static string GetComputerRowClass(Computer computer, GameSession? session)
    {
        return session is not null && GameSessionTiming.IsPastPlannedEnd(session)
            ? "computer-row row-overdue"
            : computer.Status?.Code switch
            {
                ComputerStatusCodes.Available => "computer-row row-available",
                ComputerStatusCodes.Busy => "computer-row row-busy",
                ComputerStatusCodes.Reserved => "computer-row row-reserved",
                ComputerStatusCodes.Maintenance => "computer-row row-maintenance",
                ComputerStatusCodes.Disabled => "computer-row row-disabled",
                _ => "computer-row"
            };
    }

    private static string GetComputerIndicatorClass(Computer computer, GameSession? session)
    {
        return session is not null && GameSessionTiming.IsPastPlannedEnd(session)
            ? "indicator-overdue"
            : computer.Status?.Code switch
            {
                ComputerStatusCodes.Available => "indicator-available",
                ComputerStatusCodes.Busy => "indicator-busy",
                ComputerStatusCodes.Reserved => "indicator-reserved",
                ComputerStatusCodes.Maintenance => "indicator-maintenance",
                ComputerStatusCodes.Disabled => "indicator-disabled",
                _ => "indicator-unknown"
            };
    }

    private static string GetComputerStateText(Computer computer, GameSession? session)
    {
        if (session is not null)
        {
            if (GameSessionTiming.IsInGracePeriod(session))
            {
                var graceLeft = GameSessionTiming.GetGraceTimeLeft(session);
                return graceLeft is null
                    ? "Время на продление"
                    : $"Продление · осталось {FormatSessionDuration(graceLeft.Value)}";
            }

            return GameSessionTiming.IsPastPlannedEnd(session)
                ? "Завершение сессии"
                : "Сессия активна";
        }

        return computer.Status?.Code switch
        {
            ComputerStatusCodes.Available => "Готов к запуску",
            ComputerStatusCodes.Reserved => "Зарезервирован",
            ComputerStatusCodes.Maintenance => "Требует обслуживания",
            ComputerStatusCodes.Disabled => "Питание выключено",
            _ => "Статус неизвестен"
        };
    }

    private static string GetComputerStateTextClass(Computer computer, GameSession? session)
    {
        return session is not null && GameSessionTiming.IsPastPlannedEnd(session)
            ? "text-danger fw-semibold"
            : computer.Status?.Code switch
            {
                ComputerStatusCodes.Available => "text-success",
                ComputerStatusCodes.Busy => "text-primary",
                ComputerStatusCodes.Reserved => "text-warning-emphasis",
                ComputerStatusCodes.Maintenance => "text-danger",
                ComputerStatusCodes.Disabled => "text-secondary",
                _ => "text-muted"
            };
    }

    private static string GetComputerActionHint(Computer computer, GameSession? session)
    {
        if (session is not null)
        {
            return GameSessionTiming.IsInGracePeriod(session)
                ? "Продлите сеанс или он завершится автоматически"
                : GameSessionTiming.IsPastPlannedEnd(session)
                    ? "Сессия скоро завершится"
                    : "Можно продлить или добавить время";
        }

        return computer.Status?.Code switch
        {
            ComputerStatusCodes.Available => "Правая кнопка: начать сессию",
            ComputerStatusCodes.Reserved => "Можно начать сессию по брони",
            ComputerStatusCodes.Maintenance => "Запуск недоступен",
            ComputerStatusCodes.Disabled => "Правая кнопка: включить",
            _ => "Правая кнопка: действия"
        };
    }

    private static string GetSessionTimeLeftText(GameSession session)
    {
        if (GameSessionTiming.IsInGracePeriod(session))
        {
            var graceLeft = GameSessionTiming.GetGraceTimeLeft(session);
            return graceLeft is null
                ? "авто-завершение"
                : $"на продление {FormatSessionDuration(graceLeft.Value)}";
        }

        var timeLeft = session.PlannedEndAt - DateTime.UtcNow;
        if (timeLeft <= TimeSpan.Zero)
        {
            return "авто-завершение";
        }

        return FormatSessionDuration(timeLeft);
    }

    private static string GetSessionTimeTextClass(GameSession session)
    {
        if (GameSessionTiming.IsInGracePeriod(session))
        {
            return "small text-danger fw-semibold";
        }

        var timeLeft = session.PlannedEndAt - DateTime.UtcNow;
        return timeLeft <= TimeSpan.Zero
            ? "small text-danger fw-semibold"
            : timeLeft.TotalMinutes <= 15
                ? "small text-warning-emphasis fw-semibold"
                : "small text-muted";
    }

    private static int GetSessionProgressPercent(GameSession session)
    {
        var total = GameSessionTiming.GetAutoCompleteAt(session) - session.StartedAt;
        if (total.TotalSeconds <= 0)
        {
            return 100;
        }

        var elapsed = DateTime.UtcNow - session.StartedAt;
        return Math.Clamp((int)Math.Round(elapsed.TotalSeconds / total.TotalSeconds * 100), 0, 100);
    }

    private static string GetSessionProgressClass(GameSession session)
    {
        if (GameSessionTiming.IsInGracePeriod(session))
        {
            return "bg-danger";
        }

        var timeLeft = session.PlannedEndAt - DateTime.UtcNow;
        return timeLeft <= TimeSpan.Zero
            ? "bg-danger"
            : timeLeft.TotalMinutes <= 15
                ? "bg-warning"
                : "bg-primary";
    }

    private static string FormatSessionDuration(TimeSpan duration)
    {
        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours} ч {duration.Minutes} мин"
            : $"{duration.Minutes} мин";
    }
}
