    private static string GetComputerActionHint(Computer computer, GameSession? session)
    {
        if (session is not null)
        {
            return session.PlannedEndAt < DateTime.Now
                ? "Проверьте гостя или продлите время"
                : "Можно продлить или добавить время";
        }

        return computer.Status?.Code switch
        {
