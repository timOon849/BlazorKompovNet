@page "/clients/{Id:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IClubManagementService ClubManagementService
@inject KompovRealtimeHubClient RealtimeHub
@implements IDisposable

<PageTitle>Клиент</PageTitle>

@if (client is null)
{
    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1>Клиент</h1>
            <p class="text-muted mb-0">Клиент не найден.</p>
        </div>

        <a class="btn btn-outline-secondary" href="/clients">К списку</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1>@GetClientName(client)</h1>
            <p class="text-muted mb-0">Карточка клиента, баланс и история активности.</p>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-outline-primary" href="/bookings">Создать бронь</a>
            <a class="btn btn-outline-secondary" href="/clients">К списку</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Данные клиента</h2>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Баланс</dt>
                        <dd class="col-sm-8"><strong>@FormatMoney(client.Balance)</strong></dd>

                        <dt class="col-sm-4">Телефон</dt>
                        <dd class="col-sm-8">@(client.PhoneNumber ?? "-")</dd>

                        <dt class="col-sm-4">Дата рождения</dt>
                        <dd class="col-sm-8">@ModelLabels.FormatBirthDate(client.BirthDate)</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@(client.Email ?? "-")</dd>

                        <dt class="col-sm-4">Логин</dt>
                        <dd class="col-sm-8">@(client.Login ?? "-")</dd>

                        <dt class="col-sm-4">Регистрация</dt>
                        <dd class="col-sm-8">@ClubDateTime.Format(client.RegisteredAt)</dd>

                        <dt class="col-sm-4">Активность</dt>
                        <dd class="col-sm-8">
                            @if (ClientSessions.Any(ModelLabels.IsSessionActive))
                            {
                                <span class="badge text-bg-primary">Сейчас играет</span>
                            }
                            else if (ClientBookings.Any(IsOpenBooking))
                            {
                                <span class="badge text-bg-warning">Есть бронь</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Не в клубе</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Сессии</dt>
                        <dd class="col-sm-8">@ClientSessions.Count() всего · @ClientSessions.Count(ModelLabels.IsSessionActive) активных</dd>

                        <dt class="col-sm-4">Брони</dt>
                        <dd class="col-sm-8">@ClientBookings.Count() всего · @ClientBookings.Count(IsOpenBooking) открытых</dd>

                        <dt class="col-sm-4">Пополнения</dt>
                        <dd class="col-sm-8">@FormatMoney(ClientTransactions.Where(t => !ModelLabels.IsSessionCharge(t.Type)).Sum(t => t.Amount))</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Последние транзакции</h2>
                    @if (!ClientTransactions.Any())
                    {
                        <p class="text-muted mb-0">Транзакций пока нет.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Дата</th>
                                        <th>Тип</th>
                                        <th>Способ</th>
                                        <th class="text-end">Сумма</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var transaction in ClientTransactions.Take(5))
                                    {
                                        <tr>
                                            <td>@ClubDateTime.Format(transaction.CreatedAt)</td>
                                            <td>@ModelLabels.GetTransactionTypeText(transaction.Type)</td>
                                            <td>@(transaction.PaymentType?.Name ?? "-")</td>
                                            <td class="text-end">@ModelLabels.FormatTransactionAmount(transaction)</td>
                                            <td class="text-end">
                                                <a class="btn btn-sm btn-outline-primary" href="@($"/transactions/{transaction.Id}")">Открыть</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 mb-3">Игровые сессии</h2>
                    @if (!ClientSessions.Any())
                    {
                        <p class="text-muted mb-0">Сессий пока нет.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Дата</th>
                                        <th>ПК</th>
                                        <th>Статус</th>
                                        <th class="text-end">Сумма</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var session in ClientSessions)
                                    {
                                        <tr>
                                            <td>@ClubDateTime.Format(session.StartedAt)</td>
                                            <td>@(session.Computer?.Name ?? "-")</td>
                                            <td><span class="badge @ModelLabels.GetSessionStatusBadgeClass(ModelLabels.GetSessionDisplayKey(session))">@ModelLabels.GetSessionStatusText(session)</span></td>
                                            <td class="text-end">@FormatMoney(session.TotalPrice)</td>
                                            <td class="text-end">
                                                <a class="btn btn-sm btn-outline-primary" href="@($"/sessions/{session.Id}")">Открыть</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 mb-3">Бронирования</h2>
                    @if (!ClientBookings.Any())
                    {
                        <p class="text-muted mb-0">Броней пока нет.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Время</th>
                                        <th>ПК</th>
                                        <th>Статус</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var booking in ClientBookings)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@booking.StartsAt.ToString("dd.MM HH:mm")</strong>
                                                <div class="text-muted small">до @booking.EndsAt.ToString("HH:mm")</div>
                                            </td>
                                            <td>@(booking.Computer?.Name ?? "-")</td>
                                            <td><span class="badge @GetBookingStatusBadgeClass(booking.Status)">@GetBookingStatusText(booking.Status)</span></td>
                                            <td class="text-end">
                                                <a class="btn btn-sm btn-outline-primary" href="/bookings">К броням</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Client? client;
    private IReadOnlyList<GameSession> sessions = [];
    private IReadOnlyList<Transaction> transactions = [];
    private IReadOnlyList<Booking> bookings = [];

    private IEnumerable<GameSession> ClientSessions => sessions
        .Where(session => session.ClientId == Id)
        .OrderByDescending(session => session.StartedAt);

    private IEnumerable<Transaction> ClientTransactions => transactions
        .Where(transaction => transaction.ClientId == Id)
        .OrderByDescending(transaction => transaction.CreatedAt);

    private IEnumerable<Booking> ClientBookings => bookings
        .Where(booking => booking.ClientId == Id)
        .OrderByDescending(booking => booking.StartsAt);

    protected override async Task OnParametersSetAsync()
    {
        RealtimeHub.DataChanged -= OnRealtimeDataChanged;
        RealtimeHub.DataChanged += OnRealtimeDataChanged;

        await ReloadAsync();
        var shift = await ClubManagementService.GetCurrentShiftAsync();
        var clubId = shift?.ClubId
            ?? sessions.FirstOrDefault()?.ClubId
            ?? bookings.FirstOrDefault()?.ClubId;
        await RealtimeHub.EnsureConnectedAsync(clientId: Id, clubId: clubId);
    }

    private async Task OnRealtimeDataChanged(KompovRealtimeChange change)
    {
        if (change.ClientId is int changedClient && changedClient != Id)
            return;

        await InvokeAsync(async () =>
        {
            await ReloadAsync();
            StateHasChanged();
        });
    }

    private async Task ReloadAsync()
    {
        client = await ClubManagementService.GetClientAsync(Id);
        sessions = await ClubManagementService.GetSessionsAsync();
        transactions = await ClubManagementService.GetTransactionsAsync();
        bookings = await ClubManagementService.GetBookingsAsync();
    }

    public void Dispose()
    {
        RealtimeHub.DataChanged -= OnRealtimeDataChanged;
    }

    private static bool IsOpenBooking(Booking booking)
    {
        return booking.Status == BookingStatus.Created || booking.Status == BookingStatus.Active;
    }

    private static string GetClientName(Client client)
    {
        return $"{client.FirstName} {client.LastName}";
    }

    private static string GetBookingStatusText(string status)
    {
        return status switch
        {
            BookingStatus.Created => "Создана",
            BookingStatus.Active => "Активна",
            BookingStatus.Completed => "Завершена",
            BookingStatus.Cancelled => "Отменена",
            BookingStatus.NoShow => "Неявка",
            _ => status
        };
    }

    private static string GetBookingStatusBadgeClass(string status)
    {
        return status switch
        {
            BookingStatus.Created => "text-bg-warning",
            BookingStatus.Active => "text-bg-primary",
            BookingStatus.Completed => "text-bg-success",
            BookingStatus.Cancelled => "text-bg-secondary",
            BookingStatus.NoShow => "text-bg-danger",
            _ => "text-bg-light"
        };
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} ₽";
    }
}
