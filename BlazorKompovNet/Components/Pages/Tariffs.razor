@page "/tariffs"
@attribute [Authorize]
@inject IClubManagementService ClubManagementService

<PageTitle>Тарифы</PageTitle>

<div class="tariffs-page">
    <header class="tariffs-page__header mb-4">
        <div>
            <h1 class="mb-1">Тарифы</h1>
            <p class="text-muted mb-0">Цены по зонам клуба. Почасовые тарифы умножаются на выбранное количество часов.</p>
        </div>
    </header>

    @if (tariffs is null || zones is null)
    {
        <div class="tariffs-page__loading">
            <div class="spinner-border text-primary" role="status"></div>
            <span class="ms-2 text-muted">Загрузка тарифов…</span>
        </div>
    }
    else if (!tariffs.Any())
    {
        <div class="alert alert-warning mb-0">Активные тарифы не найдены.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var tariff in tariffs)
            {
                <div class="col-12 col-xl-6">
                    <article class="tariff-card @(tariff.IsHourly ? "tariff-card--hourly" : "tariff-card--package")">
                        <div class="tariff-card__head">
                            <div>
                                <span class="tariff-card__type">@(tariff.IsHourly ? "Почасовой" : "Пакет")</span>
                                <h2 class="tariff-card__title">@tariff.Name</h2>
                                @if (!string.IsNullOrWhiteSpace(tariff.Description))
                                {
                                    <p class="tariff-card__desc">@tariff.Description</p>
                                }
                            </div>
                            <div class="tariff-card__meta">
                                @if (tariff.IsHourly)
                                {
                                    <span class="tariff-card__duration">за час</span>
                                }
                                else
                                {
                                    <span class="tariff-card__duration">@FormatDuration(tariff.Duration)</span>
                                }
                            </div>
                        </div>

                        <div class="tariff-card__zones">
                            @foreach (var zone in zones)
                            {
                                var tariffZone = tariff.TariffZones.FirstOrDefault(tz => tz.ZoneId == zone.Id && tz.IsActive);
                                var hasPrice = tariffZone is not null;

                                <div class="tariff-zone-row @(hasPrice ? null : "tariff-zone-row--empty")">
                                    <div class="tariff-zone-row__info">
                                        <span class="tariff-zone-row__name">@zone.Name</span>
                                        @if (ZoneDisplay.HasHardwareInfo(zone))
                                        {
                                            <span class="tariff-zone-row__specs text-muted">
                                                @ZoneDisplay.GetHardwareLine(zone)
                                            </span>
                                        }
                                    </div>
                                    <div class="tariff-zone-row__price">
                                        @if (hasPrice)
                                        {
                                            <strong>@FormatPrice(tariffZone!.Price, tariff.IsHourly)</strong>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>

@code {
    private IReadOnlyList<Tariff>? tariffs;
    private IReadOnlyList<ComputerZone>? zones;

    protected override async Task OnInitializedAsync()
    {
        tariffs = await ClubManagementService.GetTariffsAsync();
        zones = await ClubManagementService.GetZonesAsync();
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1 && duration.Minutes == 0)
        {
            return $"{(int)duration.TotalHours} ч";
        }

        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours} ч {duration.Minutes} мин";
        }

        return $"{duration.Minutes} мин";
    }

    private static string FormatPrice(decimal value, bool isHourly) =>
        isHourly ? $"{value:N0} ₽/ч" : $"{value:N0} ₽";
}
