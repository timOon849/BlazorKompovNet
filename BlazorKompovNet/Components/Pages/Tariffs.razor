@page "/tariffs"
@attribute [Authorize]
@inject IClubManagementService ClubManagementService

<PageTitle>Тарифы</PageTitle>

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1>Тарифы</h1>
        <p class="text-muted mb-0">Справочник тарифов и цен по залам клуба KompovNet (только просмотр).</p>
    </div>
</div>

@if (tariffs is null || zones is null)
{
    <p><em>Загрузка данных...</em></p>
}
else if (!tariffs.Any())
{
    <div class="alert alert-warning mb-0">Активные тарифы не найдены.</div>
}
else
{
    @foreach (var tariff in tariffs)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h2 class="h5 mb-1">@tariff.Name</h2>
                        <p class="text-muted mb-0">@(tariff.Description ?? "Без описания")</p>
                    </div>
                    <span class="badge text-bg-success">Активен</span>
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-3">Длительность</dt>
                    <dd class="col-sm-9">@FormatDuration(tariff.Duration)</dd>

                    <dt class="col-sm-3">Тип</dt>
                    <dd class="col-sm-9">@(tariff.IsHourly ? "Почасовой (цена × часы)" : "Фиксированный пакет")</dd>
                </dl>

                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Зона</th>
                                <th class="text-end">Цена</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var zone in zones)
                            {
                                var tariffZone = tariff.TariffZones.FirstOrDefault(tz => tz.ZoneId == zone.Id && tz.IsActive);
                                <tr>
                                    <td>@zone.Name</td>
                                    <td class="text-end">@(tariffZone is null ? "—" : FormatMoney(tariffZone.Price))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private IReadOnlyList<Tariff>? tariffs;
    private IReadOnlyList<ComputerZone>? zones;

    protected override async Task OnInitializedAsync()
    {
        tariffs = await ClubManagementService.GetTariffsAsync();
        zones = await ClubManagementService.GetZonesAsync();
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1 && duration.Minutes == 0)
        {
            return $"{(int)duration.TotalHours} ч";
        }

        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours} ч {duration.Minutes} мин";
        }

        return $"{duration.Minutes} мин";
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} ₽";
    }
}
