@page "/transactions/{Id:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IClubManagementService ClubManagementService

<PageTitle>Транзакция</PageTitle>

@if (transaction is null)
{
    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1>Транзакция</h1>
            <p class="text-muted mb-0">Операция не найдена.</p>
        </div>

        <a class="btn btn-outline-secondary" href="/transactions">К списку</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1>Транзакция #@transaction.Id</h1>
            <p class="text-muted mb-0">
                @ModelLabels.GetTransactionTypeText(transaction.Type)
                · @GetStatusText(transaction.Status)
                · @FormatTransactionAmount(transaction)
                · @ClubDateTime.Format(transaction.CreatedAt)
            </p>
        </div>

        <div class="d-flex gap-2">
            @if (transaction.GameSessionId is not null)
            {
                <a class="btn btn-outline-primary" href="@($"/sessions/{transaction.GameSessionId}")">Открыть сессию</a>
            }
            <a class="btn btn-outline-secondary" href="/transactions">К списку</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h2 class="h5 mb-3">Подробности</h2>

            <dl class="row mb-0">
                <dt class="col-sm-4">ID транзакции</dt>
                <dd class="col-sm-8">@transaction.Id</dd>

                <dt class="col-sm-4">Тип операции</dt>
                <dd class="col-sm-8">@ModelLabels.GetTransactionTypeText(transaction.Type) (@transaction.Type)</dd>

                <dt class="col-sm-4">Сумма</dt>
                <dd class="col-sm-8">@FormatTransactionAmount(transaction)</dd>

                <dt class="col-sm-4">Статус</dt>
                <dd class="col-sm-8">@GetStatusText(transaction.Status) (@transaction.Status)</dd>

                <dt class="col-sm-4">Дата создания</dt>
                <dd class="col-sm-8">@ClubDateTime.Format(transaction.CreatedAt, "dd.MM.yyyy HH:mm:ss")</dd>

                <dt class="col-sm-4">Клуб</dt>
                <dd class="col-sm-8">
                    @if (transaction.Club is not null)
                    {
                        <span>@transaction.Club.Name (ID @transaction.ClubId)</span>
                    }
                    else
                    {
                        <span>ID @transaction.ClubId</span>
                    }
                </dd>

                <dt class="col-sm-4">Клиент</dt>
                <dd class="col-sm-8">
                    @if (transaction.ClientId is null)
                    {
                        <span>-</span>
                    }
                    else if (transaction.Client is not null)
                    {
                        <a href="@($"/clients/{transaction.ClientId}")">@GetClientName(transaction.Client)</a>
                        @if (!string.IsNullOrWhiteSpace(transaction.Client.PhoneNumber))
                        {
                            <span class="text-muted"> · @transaction.Client.PhoneNumber</span>
                        }
                        <span class="text-muted"> · ID @transaction.ClientId</span>
                    }
                    else
                    {
                        <span>ID @transaction.ClientId</span>
                    }
                </dd>

                <dt class="col-sm-4">Способ оплаты</dt>
                <dd class="col-sm-8">
                    @if (transaction.PaymentType is not null)
                    {
                        <span>@transaction.PaymentType.Name</span>
                        @if (!string.IsNullOrWhiteSpace(transaction.PaymentType.Code))
                        {
                            <span class="text-muted"> (@transaction.PaymentType.Code)</span>
                        }
                        @if (transaction.PaymentType.IsBonus)
                        {
                            <span class="badge text-bg-info ms-1">Бонусы</span>
                        }
                        <span class="text-muted"> · ID @transaction.PaymentTypeId</span>
                    }
                    else
                    {
                        <span>ID @transaction.PaymentTypeId</span>
                    }
                </dd>

                <dt class="col-sm-4">Смена кассира</dt>
                <dd class="col-sm-8">
                    @if (transaction.CashierShiftId is null)
                    {
                        <span>-</span>
                    }
                    else if (transaction.CashierShift is not null)
                    {
                        <span>@GetShiftText(transaction.CashierShift)</span>
                        <span class="text-muted"> · ID @transaction.CashierShiftId</span>
                    }
                    else
                    {
                        <span>ID @transaction.CashierShiftId</span>
                    }
                </dd>

                <dt class="col-sm-4">Игровая сессия</dt>
                <dd class="col-sm-8">
                    @if (transaction.GameSessionId is null)
                    {
                        <span>-</span>
                    }
                    else
                    {
                        <a href="@($"/sessions/{transaction.GameSessionId}")">Сессия #@transaction.GameSessionId</a>
                    }
                </dd>
            </dl>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Transaction? transaction;

    protected override async Task OnParametersSetAsync()
    {
        transaction = await ClubManagementService.GetTransactionAsync(Id);
    }

    private static bool IsSessionCharge(Transaction transaction)
    {
        return ModelLabels.IsSessionCharge(transaction.Type);
    }

    private static string GetClientName(Client? client)
    {
        return client is null ? "-" : $"{client.FirstName} {client.LastName}";
    }

    private static string GetShiftText(CashierShift? shift)
    {
        return shift is null
            ? "-"
            : $"{shift.Cashier?.FullName ?? "Кассир"} · открыта {ClubDateTime.Format(shift.OpenedAt)}"
               + (shift.ClosedAt is null ? " · открыта" : $" · закрыта {ClubDateTime.Format(shift.ClosedAt.Value)}");
    }

    private static string GetStatusText(string status)
    {
        return status switch
        {
            PaymentStatus.Pending => "Ожидает",
            PaymentStatus.Paid => "Оплачено",
            PaymentStatus.Refunded => "Возврат",
            PaymentStatus.Cancelled => "Отменено",
            _ => status
        };
    }

    private static string FormatTransactionAmount(Transaction transaction)
    {
        var prefix = IsSessionCharge(transaction) ? "-" : "+";
        return $"{prefix}{FormatMoney(transaction.Amount)}";
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} ₽";
    }
}
