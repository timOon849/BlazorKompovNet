@page "/clients/register"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IClubManagementService ClubManagementService

<PageTitle>Регистрация гостя</PageTitle>

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1>Регистрация гостя</h1>
        <p class="text-muted mb-0">Создание карточки посетителя с полными данными для кассы и мобильного приложения.</p>
    </div>

    <a class="btn btn-outline-secondary" href="club-management">К управлению клубом</a>
</div>

@if (!string.IsNullOrWhiteSpace(notification))
{
    <div class="alert @notificationClass">@notification</div>
}

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <h2 class="h5 mb-3">Данные гостя</h2>

                <div class="mb-3">
                    <label class="form-label" for="firstName">Имя <span class="text-danger">*</span></label>
                    <input class="form-control" id="firstName" @bind="firstName" required />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="lastName">Фамилия <span class="text-danger">*</span></label>
                    <input class="form-control" id="lastName" @bind="lastName" required />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="phone">Телефон</label>
                    <input class="form-control" id="phone" placeholder="+7 900 000-00-00" @bind="phoneNumber" />
                    <div class="form-text">Нужен для поиска гостя на кассе и в мобильном приложении.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="birthDate">Дата рождения</label>
                    <InputDate class="form-control" id="birthDate" @bind-Value="birthDate" />
                    <div class="form-text">Необязательно для кассы, но нужна для регистрации через клиентское приложение.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="email">Email</label>
                    <input class="form-control" id="email" type="email" placeholder="guest@example.com" @bind="email" />
                </div>

                <hr class="my-4" />

                <h2 class="h6 mb-3 text-muted">Доступ в мобильное приложение</h2>
                <p class="small text-muted">Логин и пароль можно оставить пустыми для гостя без мобильного аккаунта.</p>

                <div class="mb-3">
                    <label class="form-label" for="login">Логин</label>
                    <input class="form-control" id="login" @bind="login" autocomplete="off" />
                    <div class="form-text">Если указан — потребуется пароль для входа в мобильное приложение.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="password">Пароль</label>
                    <input class="form-control" id="password" type="password" @bind="password" autocomplete="new-password" />
                </div>

                <button class="btn btn-primary" type="button" disabled="@isSubmitting" @onclick="RegisterClientAsync">
                    @(isSubmitting ? "Регистрация..." : "Зарегистрировать")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string firstName = string.Empty;
    private string lastName = string.Empty;
    private string? phoneNumber;
    private DateTime? birthDate;
    private string? email;
    private string? login;
    private string? password;
    private string? notification;
    private string notificationClass = "alert-info";
    private bool isSubmitting;

    private async Task RegisterClientAsync()
    {
        if (string.IsNullOrWhiteSpace(firstName) || string.IsNullOrWhiteSpace(lastName))
        {
            notification = "Укажите имя и фамилию гостя.";
            notificationClass = "alert-warning";
            return;
        }

        if (!string.IsNullOrWhiteSpace(login) && string.IsNullOrWhiteSpace(password))
        {
            notification = "Укажите пароль для выбранного логина.";
            notificationClass = "alert-warning";
            return;
        }

        isSubmitting = true;

        DateOnly? birthDateValue = birthDate.HasValue
            ? DateOnly.FromDateTime(birthDate.Value)
            : null;

        var result = await ClubManagementService.RegisterClientAsync(
            firstName,
            lastName,
            phoneNumber,
            email,
            birthDateValue,
            login,
            password);

        isSubmitting = false;
        notification = result.Message;
        notificationClass = result.Succeeded ? "alert-success" : "alert-danger";

        if (!result.Succeeded)
        {
            return;
        }

        firstName = string.Empty;
        lastName = string.Empty;
        phoneNumber = null;
        birthDate = null;
        email = null;
        login = null;
        password = null;
    }
}
